
# ==============================================================================
# SPRING BOOT BACKEND - ENVIRONMENT VARIABLES CONFIG (EXAMPLE)
# ==============================================================================
# Network Routing Guidelines:
# - Use 'localhost' if running the application natively via IDE (IntelliJ, VS Code).
# - Use container names (e.g., 'postgres', 'kafka', 'keycloak') if running inside 
#   the custom Docker network infrastructure.

# ==============================================================================
# DATABASE CONFIGURATION
# ==============================================================================
# PostgreSQL Connection Parameters mapped by Spring Datasource
DB_HOST=localhost
DB_PORT=5432
DB_NAME=platform
DB_USER=platform
DB_PASSWORD=your-postgres-secure-password

# ==============================================================================
# MESSAGE BROKER CONFIGURATION
# ==============================================================================
# Spring Kafka bootstrap signaling endpoint for event-driven processing
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ==============================================================================
# SECURITY & IDENTITY MANAGEMENT
# ==============================================================================
# Spring Security / Resource Server OAuth2 Validation Constraints
KEYCLOAK_SERVER_URL=http://localhost:8081
KEYCLOAK_REALM=platform
KEYCLOAK_CLIENT_ID=platform-backend
KEYCLOAK_CLIENT_SECRET=your-openid-client-uuid-secret

# OpenID Connect (OIDC) Token Verification Endpoints
JWT_ISSUER_URI=http://localhost:8081/realms/platform
JWT_AUDIENCE=platform-api

# ==============================================================================
# SECRET MANAGEMENT
# ==============================================================================
# HashiCorp Vault address and authentication token for dynamic credential lookup
VAULT_ADDR=http://localhost:8200
VAULT_ROOT_TOKEN=your-vault-development-root-token

# ==============================================================================
# TELEMETRY & OBSERVABILITY
# ==============================================================================
# OpenTelemetry Java Agent destination for distributed tracing, metrics, and logs
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=backend

# ==============================================================================
# PROFILES & FEATURE FLAGS
# ==============================================================================
# Active Spring profile determination (controls application-<profile>.yml loading)
SPRING_PROFILES_ACTIVE=local

# Architectural application toggle switches for conditional Bean initialization
FEATURE_AI_ENABLED=true
FEATURE_KAFKA_ENABLED=true
FEATURE_OBSERVABILITY_ENABLED=true
FEATURE_SECURITY_ENABLED=true