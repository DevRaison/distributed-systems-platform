# ==============================================================================
# NEXT.JS FRONTEND - ENVIRONMENT VARIABLES CONFIG (EXAMPLE)
# ==============================================================================
# WARNING: Security Guardrail for Next.js Framework
# Variables prefixed with NEXT_PUBLIC_ are automatically bundled into the 
# client-side javascript package and will be visible to the public browser.
# DO NOT place private API keys or database credentials under this prefix.
#
# Architectural Layout:
# Nginx operates as our unified Reverse Proxy/Edge Gateway listening on port 80.
# Both native local execution and multi-stage container builds must target 
# this ingress point to handle Cross-Origin Resource Sharing (CORS) properly.

# Public API Gateways (Ingress routes managed by Nginx)
NEXT_PUBLIC_API_URL=http://localhost/api
NEXT_PUBLIC_AI_URL=http://localhost/ai

# Project Meta Configurations
PROJECT_NAME=distributed-systems-platform
ENVIRONMENT=local