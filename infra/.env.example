
# ==============================================================================
# DISTRIBUTED SYSTEMS PLATFORM - MASTER CONFIGURATION (EXAMPLE)
# ==============================================================================
# General orchestration and landscape naming
PROJECT_NAME=distributed-systems-platform
ENVIRONMENT=local

# ==============================================================================
# DATABASE & STORAGE (PostgreSQL, Redis & pgAdmin)
# ==============================================================================
# Core Relational Database configuration (PostgreSQL 17)
POSTGRES_DB=platform
POSTGRES_USER=platform
POSTGRES_PASSWORD=your-postgres-secure-password

# In-memory data structure store (Caching and Rate Limiting)
REDIS_HOST=redis
REDIS_PORT=6379

# Web-based administration tool for PostgreSQL management
PGADMIN_EMAIL=admin@local.dev
PGADMIN_PASSWORD=your-pgadmin-secure-password

# ==============================================================================
# MESSAGING & STREAMING (Apache Kafka)
# ==============================================================================
# Event Broker entry point for decoupled microservices communication
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# ==============================================================================
# IDENTITY & SECURITY (Keycloak, Vault & JWT)
# ==============================================================================
# Identity and Access Management (IAM) - Bootstrap administrator credentials
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=your-keycloak-secure-password

# OpenID Connect (OIDC) / OAuth2 specifications for client applications
KEYCLOAK_REALM=platform
KEYCLOAK_SERVER_URL=http://keycloak:8080
KEYCLOAK_CLIENT_ID=platform-backend
KEYCLOAK_CLIENT_SECRET=your-openid-client-uuid-secret

# Secret Management Engine (HashiCorp Vault)
VAULT_ADDR=http://vault:8200
VAULT_ROOT_TOKEN=your-vault-development-root-token

# JSON Web Token (JWT) validation constraints for Resource Servers
JWT_ISSUER_URI=http://keycloak:8080/realms/platform
JWT_AUDIENCE=platform-api

# ==============================================================================
# CORE BACKEND (Spring Boot) & JVM CONFIG
# ==============================================================================
# Spring Boot framework profile routing configuration
SPRING_PROFILES_ACTIVE=docker

# Java Virtual Machine tuning arguments optimized for containerized layouts
JAVA_TOOL_OPTIONS="-XX:MaxRAMPercentage=75.0 -XX:+UseContainerSupport"

# ==============================================================================
# EDGE GATEWAY (AI Gateway / FastAPI & SMTP Mailhog)
# ==============================================================================
# FastAPI AI Proxy Service routing parameters
AI_GATEWAY_HOST=ai-gateway
AI_GATEWAY_PORT=8000

# Local SMTP testing sandbox server (Mailhog Interface)
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@platform.local

# ==============================================================================
# OBSERVABILITY & TELEMETRY (OpenTelemetry & Grafana Stack)
# ==============================================================================
# Dashboard visualization console administrator credentials
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=your-grafana-secure-password

# Distributed tracing, metrics, and logs collection pipeline target
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=backend

# ==============================================================================
# FRONTEND APPLICATION (Next.js)
# ==============================================================================
# Public API gateway endpoints exposed to the browser client runtime
NEXT_PUBLIC_API_URL=http://localhost/api
NEXT_PUBLIC_AI_URL=http://localhost/ai

# ==============================================================================
# ARCHITECTURE FEATURE FLAGS
# ==============================================================================
# Application toggle switches for conditional sub-system execution
FEATURE_AI_ENABLED=true
FEATURE_KAFKA_ENABLED=true
FEATURE_OBSERVABILITY_ENABLED=true
FEATURE_SECURITY_ENABLED=true