# ============================================================================
# Python Bytecode & Runtime
# ============================================================================
*.py[cod]
*$py.class
__pycache__/
*.so

# ============================================================================
# Virtual Environments (Local & Monorepo)
# ============================================================================
venv/
.venv/
env/
ENV/
lib/
lib64/

# ============================================================================
# PDM & Package Managers
# ============================================================================
.pdm-python
.pdm-build/
# NOTE: pdm.lock is intentionally omitted to keep track of dependency versions

# ============================================================================
# Data Platform: Airflow, Spark & dbt
# ============================================================================
# Airflow local logs, databases and PIDs
airflow/logs/
airflow/airflow.db
airflow/*.pid

# Spark logs, history, and temporary warehouses
*.spec
metastore_db/
spark-warehouse/
derby.log

# dbt runtime artifacts and generated packages
target/
dbt_packages/
dbt_modules/
logs/

# ============================================================================
# Data Science & Machine Learning (Jupyter/ML Models)
# ============================================================================
.ipynb_checkpoints/
*/.ipynb_checkpoints/
.chunks/

# Heavy model weights and serialized pipelines (Prevents committing large binaries)
*.pkl
*.joblib
*.h5
*.pb
*.onnx

# ============================================================================
# Testing & Coverage
# ============================================================================
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
.pact/

# ============================================================================
# Type Checking / Linters
# ============================================================================
.mypy_cache/
.ruff_cache/
.pyre/
.tox/
.nox/

# ============================================================================
# Build Artifacts & Packaging
# ============================================================================
build/
dist/
site/
*.egg-info/
.eggs/
pip-wheel-metadata/

# ============================================================================
# Logs
# ============================================================================
*.log
logs/
*.out

# ============================================================================
# IDEs & Editor Configuration (Cross-OS Protection)
# ============================================================================
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# ============================================================================
# Environment Variables & Secrets
# ============================================================================
.env
.env.*
*.env
# Block local certificates and keys often generated by data tools
*.pem
*.key
*.pub
secrets.yaml
!**/streaming/topics/*.yaml # Force Git to track infrastructure Kafka topic definitions

# ============================================================================
# OS Files & Temporary Files
# ============================================================================
.DS_Store
Thumbs.db
tmp/
temp/
.cache/
